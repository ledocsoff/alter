{
    "appId": "com.alter.studio",
    "productName": "Alter",
    "directories": {
        "output": "release"
    },
    "files": [
        "dist/**/*",
        "electron/**/*",
        "server.js",
        "server-runner.js",
        "package.json"
    ],
    "publish": {
        "provider": "github",
        "owner": "ledocsoff",
        "repo": "alter"
    },
    "mac": {
        "category": "public.app-category.developer-tools",
        "target": [
            "dmg",
            "zip"
        ],
        "icon": "public/icons/icon.png",
        "identity": null,
        "hardenedRuntime": false,
        "gatekeeperAssess": false
    },
    "win": {
        "target": [
            "nsis"
        ],
        "icon": "public/icons/icon.png"
    },
    "linux": {
        "target": [
            "AppImage"
        ],
        "icon": "public/icons/icon.png"
    },
    "nsis": {
        "oneClick": true,
        "createDesktopShortcut": true
    }
}