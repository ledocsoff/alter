{
    "appId": "com.alter.studio",
    "productName": "Alter",
    "directories": {
        "output": "release"
    },
    "files": [
        "dist/**/*",
        "electron/**/*",
        "server.js",
        "server-runner.js",
        "package.json"
    ],
    "publish": {
        "provider": "github",
        "owner": "ledocsoff",
        "repo": "alter"
    },
    "mac": {
        "category": "public.app-category.developer-tools",
        "target": [
            "dmg",
            "zip"
        ],
        "icon": "public/icons/icon.png",
        "identity": null,
        "hardenedRuntime": false,
        "gatekeeperAssess": false
    },
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": [
                    "x64",
                    "ia32"
                ]
            }
        ],
        "icon": "public/icons/icon.png",
        "artifactName": "Alter-Setup-${version}.${ext}"
    },
    "linux": {
        "target": [
            "AppImage"
        ],
        "icon": "public/icons/icon.png"
    },
    "nsis": {
        "oneClick": true,
        "createDesktopShortcut": true,
        "installerIcon": "public/icons/icon.png",
        "uninstallerIcon": "public/icons/icon.png",
        "shortcutName": "Alter",
        "artifactName": "Alter-Setup-${version}.${ext}",
        "requestedExecutionLevel": "user"
    }
}